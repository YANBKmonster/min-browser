{
  "name": "minimal-chromium-browser",
  "version": "1.0.0",
  "description": "极简 Chromium 浏览器",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build --win"
  },
  "build": {
    "appId": "com.minimal.browser",
    "productName": "MinBrowser",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "browser.html",
      "package.json"
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "portable": {
      "artifactName": "MinBrowser-${version}-portable.exe"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0"
  },
  "allowScripts": {}
}